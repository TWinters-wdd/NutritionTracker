<Window x:Class="NutritionTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NutritionTracker"
        mc:Ignorable="d"
        Title="Nutrition Tracker"
        Height="800" Width="1000"
        Background="LightSkyBlue"
        
        Icon="/Images/App_Icons/256x256_Nutrition_Logo.ico">
    <Grid>
        <Frame x:Name="Main" NavigationUIVisibility="Hidden" Margin="0, 0, 0, 70" />
        <UniformGrid Rows="1" Columns="4" Height="70" VerticalAlignment="Bottom">
            <UniformGrid.Resources>
                <Style TargetType="{x:Type Button}">
                    <!-- Sets Margins around button layout -->
                    <Setter Property="Margin" Value="5,5,5,10"></Setter>
                    
                    <!-- Overwrites the default button template with my custom rounded corners -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <!-- CornerRadius == BorderRadius in HTML -->
                                <!-- Background template binding preserves my C# HighlightButton colors -->
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="15"
                                        Cursor="Hand">

                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                
                                <!-- TRIGGER BLOCK WHEN USER HOVERS OVER BUTTON -->
                                <ControlTemplate.Triggers>
                                    <!-- IsMouseOver is equivalent to :hover pseudo-class in CSS/HTML -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <!-- When hovering, change background color of the button -->
                                        <Setter TargetName="border" Property="Background" Value="LightBlue" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </UniformGrid.Resources>
            <Button x:Name="SaladBtn" Click="SaladBtn_Click" MinWidth="150" BorderBrush="Black">
                <Image x:Name="SaladImg" Source="/Images/003-salad.png"></Image>
            </Button>
            <Button x:Name="WeightBtn" Click="WeightBtn_Click" MinWidth="150" BorderBrush="Black">
                <Image x:Name="WeightImg" Source="/Images/002-dumbbell.png"></Image>
            </Button>
            <Button x:Name="TrophyBtn" Click="TrophyBtn_Click" MinWidth="150" BorderBrush="Black">
                <Image x:Name="TrophyImg" Source="/Images/001-trophy.png"></Image>
            </Button>
            <Button x:Name="SettingsBtn" Click="SettingsBtn_Click" MinWidth="150" BorderBrush="Black">
                <Image x:Name="SettingsImg" Source="/Images/004-gear.png"></Image>
            </Button>
        </UniformGrid>
    </Grid>
</Window>
