<Page x:Class="NutritionTracker.NutritionPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:NutritionTracker"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="NutritionTracker"
        mc:Ignorable="d"
        d:DesignHeight="450"
        d:DesignWidth="1000"
        Background="LightSkyBlue">

    <Grid x:Name="LayoutRoot">
        <Grid.Resources>
            <Style TargetType="{x:Type Button}">
                <Setter Property="Margin" Value="8,5,8,12"></Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="15"
                                    Cursor="Hand">

                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">

                                    <Setter TargetName="border" Property="Background" Value="LightBlue" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Style that removes the white border on the date picker -->
            <Style x:Key="RemoveWhiteBorderDBoxStyle" TargetType="DatePickerTextBox">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePickerTextBox">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0"
                                              VerticalAlignment="Center" />
                                <ContentControl x:Name="PART_Watermark"
                                                Foreground="Navy"
                                                Focusable="False"
                                                IsHitTestVisible="False"
                                                Visibility="Collapsed"
                                                VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Date Picker Style -->
            <Style x:Key="DatePickerStyle" TargetType="DatePicker">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePicker">
                            <Border BorderBrush="Navy"
                                    BorderThickness="2"
                                    CornerRadius="5"
                                    Background="LightCyan">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <DatePickerTextBox x:Name="PART_TextBox"
                                                       Grid.Column="0"
                                                       Style="{StaticResource RemoveWhiteBorderDBoxStyle}"
                                                       Text="Filter by Date"
                                                       Background="Transparent"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Stretch"
                                                       Margin="10,0,5,0"
                                                       FontSize="30" />

                                    <Button x:Name="PART_Button"
                                            Grid.Column="1"
                                            Width="35"
                                            Background="Transparent"
                                            BorderThickness="0">
                                        <TextBlock Text="🗓️"
                                                   FontSize="14"/>
                                    </Button>

                                    <Popup x:Name="PART_Popup"
                                        AllowsTransparency="True"
                                        Placement="Bottom"
                                        PlacementTarget="{Binding ElementName=PART_TextBox}"
                                        StaysOpen="False"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label FontSize="30"
               Grid.Row="0" Grid.Column="0"
               VerticalAlignment="Center"
               HorizontalAlignment="Center">
            <TextBlock>
                <Run Text="Entry Date: "/>
                <Run Text="{Binding ElementName=FilteredDate, Path=SelectedDate, StringFormat='{}{0:MM/dd/yyyy}', TargetNullValue='All Entries'}" />
            </TextBlock>
        </Label>

        <DatePicker x:Name="FilteredDate"
                    Grid.Row="0" Grid.Column="1"
                    Style="{StaticResource DatePickerStyle}"
                    FontSize="30"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Cursor="Hand"
                    SelectedDateChanged="FilteredDate_SelectedDateChanged"
                    Margin="0,10,5,10">
            <DatePicker.Resources>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="LayoutTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="2.5" ScaleY="2.5" />
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="Text" Value="Filter by Date"/>
                </Style>
            </DatePicker.Resources>
        </DatePicker>

        <DataGrid x:Name="DataGrid"
                  Grid.Row="1"
                  Grid.Column="0"
                  AlternatingRowBackground="DodgerBlue"
                  ColumnWidth="*"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="LightCyan"
                  HeadersVisibility="Column"
                  Margin="10"
                  >

            <DataGrid.Resources>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="FontSize" Value="16" />
                    <Setter Property="FontWeight" Value="Bold" />
                </Style>
                <Style TargetType="{x:Type DataGridRow}">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Background" Value="LightCyan" />
                    <Style.Triggers>
                        <Trigger Property="AlternationIndex" Value="1">
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date"
                                    Binding="{Binding Date}"
                                    Width="Auto"/>

                <DataGridTextColumn Header="Food Name"
                                    Binding="{Binding FoodName}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Calories per Serving"
                                    Binding="{Binding CaloriesPerServing}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Servings Eaten"
                                    Binding="{Binding TotalServings}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Total Calories"
                                    Binding="{Binding TotalCalories}"
                                    Width="1*" />
            </DataGrid.Columns>
        </DataGrid>

        <lvc:PieChart x:Name="NutritionPieChart"
                      Grid.Row="1"
                      Grid.Column="1"
                      Background="Transparent"
                      Series="{Binding Series}"
                      DataContext="{Binding RelativeSource={RelativeSource AncestorType=Page}}" Grid.RowSpan="2"
                      Margin="10"/>

        <Button x:Name="AddFoodBtn" 
                Grid.Row="2" Grid.Column="1" 
                FontSize="20pt" 
                Click="AddFoodBtn_Click"
                Background="DeepSkyBlue" Margin="10,10,10,20">
            Add New Food
        </Button>
    </Grid>

    <!-- Icons used are attributed in the settings page -->
</Page>

