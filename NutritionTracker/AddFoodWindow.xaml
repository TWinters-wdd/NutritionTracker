<Window x:Class="NutritionTracker.AddFoodWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NutritionTracker"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Title="Add Food" Height="650" Width="800"
        Icon="/Images/App_Icons/Add Food Window Logo.ico"
        Background="LightSkyBlue"
        Foreground="Navy">

    <Window.Resources>
        <Style x:Key="CircularTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="50" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Ink Free" />
            <Setter Property="Background" Value="LightCyan" />
            <Setter Property="BorderBrush" Value="Navy" />
            <Setter Property="BorderThickness" Value="2" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="25"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">

                            <ScrollViewer x:Name="PART_ContentHost" Margin="2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Style that removes the white border on the date picker -->
        <Style x:Key="RemoveWhiteBorderDBoxStyle" TargetType="DatePickerTextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center" />
                            <ContentControl x:Name="PART_Watermark"
                                            Foreground="Navy"
                                            Focusable="False"
                                            IsHitTestVisible="False"
                                            Visibility="Collapsed"
                                            VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Save Button Custom Styling -->
        <Style x:Key="SaveBtnStyle" TargetType="Button">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="100" />
            <Setter Property="FontFamily" Value="Ink Free" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="Navy" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SaveBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter TargetName="SaveBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Navy"
                                                          BlurRadius="8"
                                                          ShadowDepth="2"
                                                          Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="BorderBrush" Value="Navy" />
            <Setter Property="Foreground" Value="Navy" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="LightCyan" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          FontSize="18"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="IBeam"></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Text Block Style -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Ink Free" />
            <Setter Property="Foreground" Value="Navy"/>
            <Setter Property="FontSize" Value="16" />
        </Style>
        
        <!-- Date Picker Style -->
        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border BorderBrush="Navy"
                                BorderThickness="2"
                                CornerRadius="5"
                                Background="LightCyan">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Style="{StaticResource RemoveWhiteBorderDBoxStyle}"
                                                   Grid.Column="0"
                                                   Background="Transparent"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Stretch"
                                                   Margin="10,0,5,0"
                                                   FontSize="14" />

                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Width="35"
                                        Background="Transparent"
                                        BorderThickness="0">
                                    <TextBlock Text="🗓️"
                                               FontFamily="Times New Roman"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Button>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=PART_TextBox}"
                                       StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
            </Style.Resources>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="LightCyan"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="Navy"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"></ColumnDefinition>
                                        <ColumnDefinition Width="35"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             x:Name="PART_EditableTextBox"
                                             Background="Transparent"
                                             Margin="5,2,2,2"
                                             BorderBrush="Transparent"
                                             VerticalAlignment="Center">
                                    </TextBox>
                                    <ToggleButton Grid.Column="1"
                                                  x:Name="PART_ToggleButton"
                                                  Width="27"
                                                  Margin="3"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">

                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="ButtonBorder"
                                                        Background="Transparent"
                                                        BorderBrush="Navy"
                                                        BorderThickness="1"
                                                        CornerRadius="3">

                                                    <Path x:Name="ArrowPath"
                                                          Fill="Navy"
                                                          Data="M 0,0 L 0,8 L 8,4 Z"
                                                          Width="8"
                                                          Height="8"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#47b4f7"/>
                                                        <Setter TargetName="ArrowPath" Property="Fill" Value="White"/>
                                                    </Trigger>

                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="ArrowPath" Property="Data" Value="M 0,0 L 8,0 L 4,8 Z"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="Navy"
                                        BorderThickness="2"
                                        MaxHeight="200">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter x:Name="ItemsPresenter"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Column="0" Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Date:"/>
            <DatePicker x:Name="SelectedDatePicker"
                        SelectedDate="{x:Static sys:DateTime.Today}"
                        Style="{StaticResource DatePickerStyle}"
                        MinWidth="150"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Food Name:"/>
            <ComboBox x:Name="FoodNameBox"
                      Style="{StaticResource ComboBoxStyle}"
                      Margin="0,5,0,10" 
                      Width="150"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      StaysOpenOnEdit="True"
                      SelectionChanged="FoodNameBox_SelectionChanged"
                      
                      KeyUp="FoodNameBox_KeyUp">
                <ComboBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel VirtualizationMode="Recycling" />
                    </ItemsPanelTemplate>
                </ComboBox.ItemsPanel>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Column="0" Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Calories per Serving: "/>
            <TextBox x:Name="CaloriesPerServingBox"
                     Style="{StaticResource TextBoxStyle}"
                     Margin="0,5,0,10" 
                     MinWidth="150"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Servings:" />
            <TextBox x:Name="ServingsBox" Margin="0,5,0,10"
                     MinWidth="150"
                     Style="{StaticResource TextBoxStyle}"/>
        </StackPanel>

        <Expander x:Name="MacroExpander" Grid.Row="2" Grid.ColumnSpan="2"
                  IsExpanded="False"
                  ExpandDirection="Down"
                  Margin="20">
            <Expander.Header>
                <TextBlock>Macro Information</TextBlock>
            </Expander.Header>
            
            <!-- Grid for the Macro Information Expander -->
            <Grid x:Name="MacroInformation">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- First Row -->
                <StackPanel Grid.Column="0" Grid.Row="0">
                    <TextBlock HorizontalAlignment="Center">Protein (g):</TextBlock>
                    <TextBox x:Name="ProteinBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Grid.Row="0">
                    <TextBlock HorizontalAlignment="Center">Total Fat (g):</TextBlock>
                    <TextBox x:Name="TotalFatBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="2" Grid.Row="0">
                    <TextBlock HorizontalAlignment="Center">Carbohydrates (g):</TextBlock>
                    <TextBox x:Name="CarbsBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="3" Grid.Row="0">
                    <TextBlock HorizontalAlignment="Center">Sodium (g):</TextBlock>
                    <TextBox x:Name="SodiumBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="4" Grid.Row="0">
                    <TextBlock HorizontalAlignment="Center">Saturated Fat (g):</TextBlock>
                    <TextBox x:Name="SaturatedFatBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                
                <!-- Second Row -->

                <StackPanel Grid.Column="0" Grid.Row="1">
                    <TextBlock HorizontalAlignment="Center">Cholesterol (g):</TextBlock>
                    <TextBox x:Name="CholesterolBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Grid.Row="1">
                    <TextBlock HorizontalAlignment="Center">Sugar (g):</TextBlock>
                    <TextBox x:Name="SugarBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="2" Grid.Row="1">
                    <TextBlock HorizontalAlignment="Center">Calcium (g):</TextBlock>
                    <TextBox x:Name="CalciumBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="3" Grid.Row="1">
                    <TextBlock HorizontalAlignment="Center">Iron (g):</TextBlock>
                    <TextBox x:Name="IronBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="4" Grid.Row="1">
                    <TextBlock HorizontalAlignment="Center">Potassium (g):</TextBlock>
                    <TextBox x:Name="PotassiumBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                
                <!-- Third Row -->
                <StackPanel Grid.Column="1" Grid.Row="2">
                    <TextBlock HorizontalAlignment="Center">Vitamin C (g):</TextBlock>
                    <TextBox x:Name="VitaminCBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="2" Grid.Row="2">
                    <TextBlock HorizontalAlignment="Center">Vitamin E (g):</TextBlock>
                    <TextBox x:Name="VitaminEBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
                <StackPanel Grid.Column="3" Grid.Row="2">
                    <TextBlock HorizontalAlignment="Center">Vitamin D (g):</TextBlock>
                    <TextBox x:Name="VitaminDBox"
                             Style="{StaticResource CircularTextBoxStyle}"></TextBox>
                </StackPanel>
            </Grid>
        </Expander>

        <Button x:Name="SaveBtn"
                Style="{StaticResource SaveBtnStyle}"
                FontSize="24"
                Click="SaveButton_Click" 
                Grid.Row="3"
                Grid.ColumnSpan="2">
            Save</Button>
    </Grid>
</Window>
